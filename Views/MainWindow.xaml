<Window x:Class="SiapControl.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SiapControl" Height="450" Width="800">
    <DockPanel>
        <DataGrid x:Name="UsersGrid" AutoGenerateColumns="False" Margin="10" DockPanel.Dock="Top" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="Auto" IsReadOnly="True" />
                <DataGridTextColumn Header="Usuario" Binding="{Binding User}" Width="*" />
                <DataGridTextColumn Header="Ruta" Binding="{Binding Path}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10" DockPanel.Dock="Bottom">
            <Button x:Name="AddUserButton" Content="Agregar" Margin="5" Width="75" />
            <Button x:Name="UpdateButton" Content="Actualizar" Margin="5" Width="75" />
            <Button x:Name="ModulesButton" Content="Módulos" Margin="5" Width="75" IsEnabled="False" />
        </StackPanel>
    </DockPanel>
</Window>

