<Window x:Class="SiapControl.Views.InstallerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Instalador" Height="390" Width="560"
        MinHeight="340" MinWidth="500"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock x:Name="TitleText" FontWeight="SemiBold" FontSize="18"/>
            <TextBlock x:Name="VersionText" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
        </StackPanel>
        <DataGrid x:Name="UsersGrid" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="Auto" IsReadOnly="True" />
                <DataGridTextColumn Header="Usuario" Binding="{Binding User}" Width="*" />
                <DataGridTextColumn Header="Versión" Binding="{Binding Version}" Width="*" />
                <DataGridCheckBoxColumn Header="Instalar" Binding="{Binding Active}" Width="Auto" />
            </DataGrid.Columns>
        </DataGrid>
        <Button x:Name="StartButton" DockPanel.Dock="Bottom" Content="Instalar" Margin="0,14,0,0" HorizontalAlignment="Right"/>
    </DockPanel>
</Window>
