<Window x:Class="SiapControl.Views.InstallerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Instalador" Height="350" Width="500">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,5">
            <TextBlock x:Name="TitleText" FontWeight="Bold"/>
            <TextBlock x:Name="VersionText"/>
        </StackPanel>
        <DataGrid x:Name="UsersGrid" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="Auto" IsReadOnly="True" />
                <DataGridTextColumn Header="Usuario" Binding="{Binding User}" Width="*" />
                <DataGridTextColumn Header="Versión" Binding="{Binding Version}" Width="*" />
                <DataGridCheckBoxColumn Header="Instalar" Binding="{Binding Active}" Width="Auto" />
            </DataGrid.Columns>
        </DataGrid>
        <Button x:Name="StartButton" DockPanel.Dock="Bottom" Content="Instalar" Width="80" Margin="0,5,0,0" HorizontalAlignment="Right"/>
    </DockPanel>
</Window>

