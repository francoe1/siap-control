<Window x:Class="SiapControl.Views.InstallerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Instalador" Height="480" Width="700"
        MinHeight="420" MinWidth="620"
        WindowStartupLocation="CenterOwner">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Acciones">
                <MenuItem x:Name="StartMenuItem" Header="_Actualizar seleccionadas"/>
                <Separator/>
                <MenuItem x:Name="SelectAllMenuItem" Header="Seleccionar _todo"/>
                <MenuItem x:Name="ClearSelectionMenuItem" Header="_Limpiar seleccion"/>
                <MenuItem x:Name="ToggleSelectedMenuItem" Header="Invertir seleccion de la fila"/>
                <Separator/>
                <MenuItem x:Name="CloseMenuItem" Header="_Cerrar"/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar x:Name="Progress" Minimum="0" Maximum="100" Value="0" Width="180"/>
            </StatusBarItem>
        </StatusBar>

        <DockPanel Margin="16">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                <TextBlock x:Name="TitleText" FontWeight="SemiBold" FontSize="18"/>
                <TextBlock x:Name="VersionText" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
            </StackPanel>

            <ToolBarTray DockPanel.Dock="Bottom" Margin="0,12,0,0">
                <ToolBar>
                    <Button x:Name="SelectAllButton" Content="Seleccionar todo"/>
                    <Button x:Name="ClearSelectionButton" Content="Limpiar seleccion"/>
                    <Separator/>
                    <Button x:Name="StartButton" Content="Actualizar"/>
                </ToolBar>
            </ToolBarTray>

            <DataGrid x:Name="UsersGrid" AutoGenerateColumns="False">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem x:Name="ToggleSelectedContextMenuItem" Header="Invertir seleccion de la fila"/>
                        <Separator/>
                        <MenuItem x:Name="SelectAllContextMenuItem" Header="Seleccionar todo"/>
                        <MenuItem x:Name="ClearSelectionContextMenuItem" Header="Limpiar seleccion"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="Auto" IsReadOnly="True" />
                    <DataGridTextColumn Header="Usuario" Binding="{Binding User}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Version actual" Binding="{Binding Version}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Estado" Binding="{Binding Status}" Width="1.4*" IsReadOnly="True" />
                    <DataGridCheckBoxColumn Header="Actualizar" Binding="{Binding Active, UpdateSourceTrigger=PropertyChanged}" Width="Auto" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </DockPanel>
</Window>
