<Window x:Class="SiapControl.Views.AutoUpdateSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Autoupdater" Height="360" Width="430"
        MinHeight="330" MinWidth="390"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="SaveButton" Content="Guardar" Margin="0,0,8,0"/>
            <Button x:Name="CancelButton" Content="Cancelar"/>
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Actualizacion automatica" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Text="La app puede quedar en segundo plano y revisar los modulos en los dias configurados."
                       Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,3,0,16"/>

            <CheckBox x:Name="EnabledCheck" Content="Activar autoupdater programado" Margin="0,0,0,12"/>
            <CheckBox x:Name="StartWithWindowsCheck" Content="Iniciar SiapControl con Windows" Margin="0,0,0,16"/>

            <TextBlock Text="Dias" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <UniformGrid Columns="2" Margin="0,0,0,16">
                <CheckBox x:Name="SundayCheck" Content="Domingo" Margin="0,0,0,6"/>
                <CheckBox x:Name="MondayCheck" Content="Lunes" Margin="0,0,0,6"/>
                <CheckBox x:Name="TuesdayCheck" Content="Martes" Margin="0,0,0,6"/>
                <CheckBox x:Name="WednesdayCheck" Content="Miercoles" Margin="0,0,0,6"/>
                <CheckBox x:Name="ThursdayCheck" Content="Jueves" Margin="0,0,0,6"/>
                <CheckBox x:Name="FridayCheck" Content="Viernes" Margin="0,0,0,6"/>
                <CheckBox x:Name="SaturdayCheck" Content="Sabado" Margin="0,0,0,6"/>
            </UniformGrid>

            <StackPanel Orientation="Horizontal">
                <Label Content="Hora:"/>
                <TextBox x:Name="TimeText" Width="80"/>
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
