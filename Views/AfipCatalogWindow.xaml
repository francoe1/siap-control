<Window x:Class="SiapControl.Views.AfipCatalogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Catalogo ARCA" Height="560" Width="900"
        MinHeight="460" MinWidth="760"
        WindowStartupLocation="CenterOwner">
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar x:Name="Progress" Minimum="0" Maximum="100" Value="0" Width="180"/>
            </StatusBarItem>
        </StatusBar>

        <DockPanel Margin="16">
            <ToolBarTray DockPanel.Dock="Top" Margin="0,0,0,12">
                <ToolBar>
                    <Label Content="Buscar:"/>
                    <TextBox x:Name="SearchText" Width="260"/>
                    <Label Content="Orden:" Margin="10,0,0,0"/>
                    <ComboBox x:Name="SortCombo" Width="150" SelectedIndex="0">
                        <ComboBoxItem Content="Fecha release"/>
                        <ComboBoxItem Content="Nombre"/>
                    </ComboBox>
                    <Separator/>
                    <Button x:Name="RefreshButton" Content="Actualizar catalogo"/>
                    <Button x:Name="InstallButton" Content="Instalar"/>
                </ToolBar>
            </ToolBarTray>

            <DataGrid x:Name="CatalogGrid" AutoGenerateColumns="False" SelectionMode="Extended" SelectionUnit="FullRow">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" SortMemberPath="Name" Width="2*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Categoria" Binding="{Binding Category}" SortMemberPath="Category" Width="1.3*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Version" Binding="{Binding Version}" SortMemberPath="VersionSortKey" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Fecha release" Binding="{Binding ReleaseDateText}" SortMemberPath="ReleaseDateSortKey" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Estado" Binding="{Binding Status}" Width="1.2*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Progreso" Binding="{Binding ProgressText}" Width="0.8*" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </DockPanel>
</Window>
