<Window x:Class="SiapControl.Views.UserModulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Módulos" Height="340" Width="500"
        MinHeight="300" MinWidth="430"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,12">
            <Label Content="Buscar:" VerticalAlignment="Center"/>
            <TextBox x:Name="SearchText" Width="240" Margin="0,0,8,0"/>
            <Button x:Name="ReindexButton" Content="Reindexar"/>
        </StackPanel>
        <DataGrid x:Name="ModulesGrid" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nombre" Binding="{Binding AppName}" Width="*" />
                <DataGridTextColumn Header="Versión" Binding="{Binding AppVersion}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
