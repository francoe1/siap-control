<Window x:Class="SiapControl.Views.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Usuario" Height="190" Width="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Usuario:" Margin="0,0,5,5"/>
        <TextBox x:Name="UserText" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,5"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Ruta:" Margin="0,0,5,5"/>
        <TextBox x:Name="PathText" Grid.Row="1" Grid.Column="1" Margin="0,0,5,5"/>
        <Button x:Name="BrowseButton" Grid.Row="1" Grid.Column="2" Content="..." MinWidth="34" Width="34"/>

        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="SaveButton" Content="Guardar" Margin="0,0,8,0"/>
            <Button x:Name="CancelButton" Content="Cancelar"/>
        </StackPanel>
    </Grid>
</Window>
